# Copy to .env and adjust. docker compose reads it automatically.

# Where the containers publish their ports. Keep them on 127.0.0.1 so the host
# nginx is the only public entry point. Only change the bind address if nginx
# runs on a different host than the containers.
SERVER_BIND=127.0.0.1
SERVER_PORT=8090
CLIENT_BIND=127.0.0.1
CLIENT_PORT=8091

# Game server tuning.
# Simulation tick rate in ticks/second (Hz). Higher = finer simulation fidelity
# (and proportionally more CPU + snapshot bandwidth); the game feel in seconds
# is unchanged. Wall-clock pacing follows this automatically.
TICK_RATE=100
LOG_LEVEL=info
# Reject new WebSocket connections beyond this many (0 = unlimited).
MAX_CONNECTIONS=500
# Force every room to a balance preset. Leave empty for per-room defaults.
#   default = normal play   |   test = accelerated (cheap, near-instant builds)
BALANCE_PRESET=
